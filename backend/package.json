{
  "name": "backend",
  "version": "1.0.0",
  "description": "Notion Clone Backend - Express + TypeScript + Knex",
  "main": "dist/index.js",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target node",
    "start": "bun dist/index.js",
    "test": "bun test",
    "typecheck": "bunx tsc --noEmit",
    "migrate": "bunx knex migrate:latest --knexfile knexfile.ts",
    "migrate:make": "bunx knex migrate:make --knexfile knexfile.ts --migrations-directory ./migrations"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^11.0.0",
    "typescript": "^5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "pg": "^8.20.0",
    "uuid": "^13.0.0"
  }
}
